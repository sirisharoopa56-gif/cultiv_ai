# Copy this file to ".env" and fill in your own key.
# Never commit the real .env file — it's already in .gitignore.
#
# Get a free Groq API key at: https://console.groq.com/keys
#
# The app works fine without this — AI Insight enhancement on the
# AI Advisor screen just won't appear until a key is configured.
# Core crop recommendations always work regardless.

GROQ_API_KEY=your_groq_api_key_here